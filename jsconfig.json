{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./"],
      "@dcloudio/*": ["./node_modules/@dcloudio/*"]
    },
    "target": "es6",
    "module": "esnext",
    "moduleResolution": "node",
    "strict": false,
    "jsx": "preserve",
    "sourceMap": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "lib": ["es6", "dom"]
  },
  "include": [
    "**/*.js",
    "**/*.vue",
    "**/*.json"
  ],
  "exclude": [
    "node_modules",
    "uni_modules",
    "dist",
    "__pycache__"
  ]
}
